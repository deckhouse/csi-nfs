@@ -587,32 +636,38 @@ func (cs *ControllerServer) copyFromSnapshot(ctx context.Context, req *csi.Creat
 		}
 	}()
 
-	// untar snapshot archive to dst path
+	// untar snapshot archive to a staging path and atomically rename it into
